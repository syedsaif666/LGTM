{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "WebFetch(domain:localhost)",
      "WebFetch(domain:127.0.0.1)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:stackoverflow.com)",
      "WebFetch(domain:reddit.com)",
      "WebFetch(domain:developer.mozilla.org)",
      "WebFetch(domain:npmjs.com)",
      "WebFetch(domain:nextjs.org)",
      "WebFetch(domain:vercel.com)",
      "WebFetch(domain:tailwindcss.com)",
      "WebFetch(domain:fumadocs.dev)",
      "WebFetch(domain:schema.org)",
      "WebFetch(domain:developers.google.com)",
      "WebFetch(domain:search.google.com)",
      "WebFetch(domain:web.dev)",
      "WebFetch(domain:ahrefs.com)",
      "WebFetch(domain:semrush.com)",
      "WebFetch(domain:moz.com)",
      "WebFetch(domain:medium.com)",
      "WebFetch(domain:next-intl.dev)",
      "WebFetch(domain:agent-browser.dev)",
      "WebFetch(domain:linear.app)",
      "WebFetch(domain:api.github.com)",
      "WebSearch",
      "Bash(bash install.sh)",
      "Bash(npx skills *)",
      "Bash(npx prettier *)",
      "Bash(node *)",
      "Bash(wc *)",
      "Bash(git *)",
      "Bash(ls *)",
      "Bash(ls*)",
      "Bash(find *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(echo *)",
      "Bash(pwd *)",
      "Bash(which *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(cut *)",
      "Bash(tr *)",
      "Bash(diff *)",
      "Bash(stat *)",
      "Bash(file *)",
      "Bash(type *)",
      "Bash(pnpm build)",
      "Bash(pnpm dev)",
      "Bash(pnpm start)",
      "Bash(pnpm lint)",
      "Bash(pnpm lint:fix)",
      "Bash(pnpm format)",
      "Bash(gh search *)",
      "Bash(gh issue *)",
      "Bash(gh pr *)",
      "Bash(gh api *)",
      "Bash(agent-browser *)"
    ],
    "deny": [
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(**/.env*)",
      "Write(~/.ssh/**)",
      "Write(~/.aws/**)",
      "Bash(curl * | bash)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(nc *)",
      "Bash(sudo *)",
      "Bash(chmod *)",
      "Bash(chown *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Context recovered. Check STATUS.md for current status.'"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -f .claude/.onboarded || python .claude/skills/onboard/scripts/scan-placeholders.py --hook"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/source-guard.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/auto-sync.py"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true
  }
}
